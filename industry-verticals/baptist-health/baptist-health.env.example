# Baptist Health - environment template
# Copy this file to .env.local and fill in values from your XM Cloud environment.
# Or copy .env.remote.example to .env.local and use the values below as reference.

# Required: set to your Sitecore site key (baptist-health for this app).
NEXT_PUBLIC_DEFAULT_SITE_NAME=baptist-health

# Required: from XM Cloud Deploy / Experience Edge for the baptist-health site.
SITECORE_EDGE_CONTEXT_ID=
NEXT_PUBLIC_SITECORE_EDGE_CONTEXT_ID=

# Required: secret for /api/editing/render (generate or use XM Cloud value).
SITECORE_EDITING_SECRET=

# Optional: default language and personalization (see .env.remote.example for full list).
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_PERSONALIZE_SCOPE=
PERSONALIZE_MIDDLEWARE_CDP_TIMEOUT=
PERSONALIZE_MIDDLEWARE_EDGE_TIMEOUT=
SITECORE_AUTH_CLIENT_ID=
SITECORE_AUTH_CLIENT_SECRET=
